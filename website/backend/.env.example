# ============================================
# Series Untuk Mahasiswa - Environment Variables
# ============================================

# Server Configuration
PORT=3000
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5500

# KIMI AI API Configuration
# Get your API key from: https://platform.moonshot.cn/
KIMI_API_KEY=YOUR_KIMI_API_KEY

# Optional: Email Service (for newsletter notifications)
# Using SendGrid
# SENDGRID_API_KEY=your_sendgrid_api_key
# FROM_EMAIL=noreply@seriesuntukmahasiswa.com

# Using Mailgun
# MAILGUN_API_KEY=your_mailgun_api_key
# MAILGUN_DOMAIN=mg.seriesuntukmahasiswa.com

# Optional: Database (MongoDB, PostgreSQL, etc.)
# DATABASE_URL=mongodb://localhost:27017/series_mahasiswa

# Optional: JWT Secret (for admin authentication)
# JWT_SECRET=your_super_secret_jwt_key

# Optional: Admin credentials
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=your_secure_password
